# ----------------------------------------------------------------------------
# AutoSRE environment variables. Copy this file to `.env` and fill in values.
# Both `sre-helper` and `o11y-agent` read from the same schema.
# ----------------------------------------------------------------------------

# -- GCP project / location ---------------------------------------------------
# Required for both local runs and deployment.
GOOGLE_CLOUD_PROJECT=your-project-id

# Optional; defaults to us-central1 in the code.
GOOGLE_CLOUD_LOCATION=us-central1

# Required for deployment. The GCS bucket used to stage code for Agent Engine.
GOOGLE_CLOUD_STORAGE_BUCKET=your-staging-bucket

# Tells the Google GenAI SDK to use the Vertex AI backend instead of the
# public GenAI API. Leave as True for this project.
GOOGLE_GENAI_USE_VERTEXAI=True

# -- IAM setup (scripts/setup_iam.sh) -----------------------------------------
# Required by scripts/setup_iam.sh when binding roles to the SPIFFE identity.
ORGANIZATION_ID=your-organization-id

# -- o11y-agent MCP toolsets --------------------------------------------------
# Each toolset is resolved from Agent Registry. These env vars override the
# defaults baked into the code; leave blank to use defaults.
LOGGING_MCP_SERVER_ID=projects/your-project-id/locations/global/mcpServers/your-logging-mcp-server-id
TRACE_MCP_SERVER_ID=projects/your-project-id/locations/global/mcpServers/your-trace-mcp-server-id
MONITORING_MCP_SERVER_ID=projects/your-project-id/locations/global/mcpServers/your-monitoring-mcp-server-id
ERROR_REPORTING_MCP_SERVER_ID=projects/your-project-id/locations/global/mcpServers/your-error-reporting-mcp-server-id

# -- Telemetry (optional) -----------------------------------------------------
# Enables the built-in Agent Engine telemetry exporter.
GOOGLE_CLOUD_AGENT_ENGINE_ENABLE_TELEMETRY=true

# Capture full GenAI message content in OTel spans. Useful for debugging;
# disable in production if payloads may contain sensitive data.
OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=true
OTEL_SEMCONV_STABILITY_OPT_IN=gen_ai_latest_experimental

# GCS bucket used by the telemetry pipeline for large message-content uploads.
# Optional; only used if set.
LOGS_BUCKET_NAME=your-logs-bucket
